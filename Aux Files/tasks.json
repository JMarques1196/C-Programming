{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile C with warnings",
      "type": "shell",
      "command": "clang",
      "args": [
        "-Wall",
        "-Wextra",
        "-Wpedantic",
        "programa.c",
        "-o",
        "programa"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
